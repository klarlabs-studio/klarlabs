---
import '@klarlabs/ui/tokens.css';

interface Props {
  title: string;
  description: string;
  theme?: 'dark' | 'light';
  /** Studio page only — honors saved kl-theme preference before paint. */
  themeToggle?: boolean;
}

const { title, description, theme = 'dark', themeToggle = false } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    {
      themeToggle && (
        <script is:inline>
          {`try {
            const saved = localStorage.getItem('kl-theme');
            if (saved === 'dark' || saved === 'light') {
              document.documentElement.setAttribute('data-theme', saved);
            }
          } catch {}`}
        </script>
      )
    }
  </head>
  <body>
    <slot />
    <script>
      import '@klarlabs/ui/kl-nav.js';
      import '@klarlabs/ui/kl-hero.js';
      import '@klarlabs/ui/kl-button.js';
      import '@klarlabs/ui/kl-product-card.js';
      import '@klarlabs/ui/kl-divider.js';
      import '@klarlabs/ui/kl-oss-card.js';
      import '@klarlabs/ui/kl-feature-card.js';
      import '@klarlabs/ui/kl-klarlabs-badge.js';
      import '@klarlabs/ui/kl-theme-toggle.js';
      import '@klarlabs/ui/kl-badge.js';
    </script>
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    background: var(--kl-surface);
    transition: background var(--kl-duration-normal) var(--kl-ease-default);
  }

  /* Avoid layout shift before custom elements upgrade */
  :not(:defined) {
    visibility: hidden;
  }
</style>
