---
import Base from '../../layouts/Base.astro';
import { articles, type Article } from '../../data/articles';
import compositionSvg from '../../charts/composition.svg?raw';
import readsSvg from '../../charts/reads.svg?raw';
import ratioSvg from '../../charts/ratio.svg?raw';
import fmtRoiSvg from '../../charts/fmt-roi.svg?raw';

const CHARTS: Record<string, string> = {
  composition: compositionSvg,
  reads: readsSvg,
  ratio: ratioSvg,
  'fmt-roi': fmtRoiSvg,
};

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: Article;
}

const { article } = Astro.props;
const dateLabel = new Date(article.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title={`${article.title} — Klarlabs`}
  description={article.dek}
  theme="dark"
>
  <div class="article-page" style={`--article-accent: ${article.accent}`}>
    <kl-nav>
      <a class="wordmark" slot="brand" href="/">klar&hairsp;<em>labs</em></a>
      <a href="/#products">Products</a>
      <a href="/#oss">Open Source</a>
      <a href="/writing/">Writing</a>
      <kl-klarlabs-badge slot="cta" href="/"></kl-klarlabs-badge>
      <a slot="drawer" href="/#products">Products</a>
      <a slot="drawer" href="/#oss">Open Source</a>
      <a slot="drawer" href="/writing/">Writing</a>
    </kl-nav>

    <kl-hero animated style="--kl-hero-accent: var(--article-accent)">
      <span slot="eyebrow">Writing · {dateLabel} · {article.readingMinutes} min read</span>
      <h1 slot="title">{article.title}</h1>
      <p slot="subtitle">{article.dek}</p>
      <span slot="actions" class="hero-meta">
        <span class="byline">By {article.author}</span>
        {article.tags.map((t) => <kl-badge variant="neutral">{t}</kl-badge>)}
      </span>
    </kl-hero>

    <main>
      <article>
        {
          article.blocks.map((block) => {
            if (block.type === 'p') return <p class="copy">{block.text}</p>;
            if (block.type === 'h') return <h2 class="subhead">{block.text}</h2>;
            if (block.type === 'quote') return <blockquote class="pullquote">{block.text}</blockquote>;
            if (block.type === 'list')
              return (
                <ul class="copy list">
                  {block.items.map((i) => (
                    <li>{i}</li>
                  ))}
                </ul>
              );
            if (block.type === 'stats')
              return (
                <div class="stats">
                  {block.stats.map((s) => (
                    <div class="stat">
                      <span class="stat-value">{s.value}</span>
                      <span class="stat-label">{s.label}</span>
                    </div>
                  ))}
                </div>
              );
            if (block.type === 'code')
              return (
                <figure class="codeblock">
                  <pre><code class={`lang-${block.lang ?? 'text'}`}>{block.code}</code></pre>
                  {(block.caption || block.href) && (
                    <figcaption>
                      {block.caption}
                      {block.href && (
                        <a href={block.href} target="_blank" rel="noreferrer">
                          {block.hrefLabel ?? 'View on GitHub'} →
                        </a>
                      )}
                    </figcaption>
                  )}
                </figure>
              );
            if (block.type === 'svg')
              return (
                <figure class="chart">
                  <div class="chart-svg" set:html={CHARTS[block.id]} />
                  <p class="chart-cmd"><span class="prompt">$</span> {block.cmd}</p>
                  {block.caption && <p class="chart-caption">{block.caption}</p>}
                </figure>
              );
            return null;
          })
        }
      </article>

      {
        article.cta && (
          <section class="cta">
            <span class="section-label">Open Source</span>
            <h2 class="subhead">{article.cta.heading}</h2>
            <p class="copy">{article.cta.body}</p>
            <kl-button size="lg" href={article.cta.href} target="_blank">
              {article.cta.label}
            </kl-button>
          </section>
        )
      }

      <a class="back" href="/writing/">← All writing</a>
    </main>

    <footer>
      <kl-klarlabs-badge href="/"></kl-klarlabs-badge>
      <span class="footer-place">Munich, Germany · © 2026 Klarlabs</span>
    </footer>
  </div>
</Base>

<style>
  .wordmark {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-md);
    font-weight: var(--kl-weight-normal);
    letter-spacing: var(--kl-tracking-tight);
    color: var(--kl-ink);
    text-decoration: none;
  }

  .wordmark em {
    color: var(--kl-accent);
    font-weight: var(--kl-weight-semibold);
    font-style: normal;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--kl-space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  .byline {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    color: var(--kl-ink-secondary);
  }

  main {
    max-inline-size: var(--kl-content-md);
    margin-inline: auto;
    padding-block: var(--kl-space-16);
    padding-inline: clamp(var(--kl-space-4), 4vw, var(--kl-space-12));
    display: grid;
    gap: var(--kl-space-8);
  }

  article {
    display: grid;
    gap: var(--kl-space-6);
  }

  .subhead {
    margin: var(--kl-space-6) 0 0;
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-lg);
    font-weight: var(--kl-weight-semibold);
    letter-spacing: var(--kl-tracking-tight);
    color: var(--kl-ink);
  }

  .copy {
    margin: 0;
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-md);
    line-height: var(--kl-leading-relaxed);
    color: var(--kl-ink-secondary);
  }

  .list {
    display: grid;
    gap: var(--kl-space-2);
    padding-inline-start: var(--kl-space-5);
  }

  .list li {
    padding-inline-start: var(--kl-space-1);
  }

  .pullquote {
    margin: var(--kl-space-4) 0;
    padding: var(--kl-space-4) var(--kl-space-6);
    border-inline-start: 3px solid var(--article-accent, var(--kl-accent));
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-lg);
    font-weight: var(--kl-weight-medium);
    line-height: var(--kl-leading-relaxed);
    color: var(--kl-ink);
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 200px), 1fr));
    gap: var(--kl-space-5);
    margin: var(--kl-space-4) 0;
    padding: var(--kl-space-6);
    border: 1px solid var(--kl-border);
    border-radius: var(--kl-radius-lg, 12px);
  }

  .stat {
    display: grid;
    gap: var(--kl-space-2);
  }

  .stat-value {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-xl, 2rem);
    font-weight: var(--kl-weight-bold);
    letter-spacing: var(--kl-tracking-tight);
    color: var(--article-accent, var(--kl-accent));
  }

  .stat-label {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    line-height: var(--kl-leading-relaxed);
    color: var(--kl-ink-tertiary);
  }

  .section-label {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-xs);
    font-weight: var(--kl-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--kl-tracking-caps);
    color: var(--article-accent, var(--kl-accent));
  }

  /* --- code blocks --- */
  .codeblock {
    margin: var(--kl-space-4) 0;
    display: grid;
    gap: var(--kl-space-2);
  }

  .codeblock pre {
    margin: 0;
    padding: var(--kl-space-5);
    background: var(--kl-surface-raised, rgba(127, 127, 127, 0.08));
    border: 1px solid var(--kl-border);
    border-radius: var(--kl-radius-lg, 12px);
    overflow-x: auto;
  }

  .codeblock code {
    font-family: var(--kl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: var(--kl-text-sm);
    line-height: var(--kl-leading-relaxed);
    color: var(--kl-ink);
    white-space: pre;
  }

  .codeblock figcaption {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    color: var(--kl-ink-tertiary);
    display: flex;
    flex-wrap: wrap;
    gap: var(--kl-space-2);
  }

  .codeblock figcaption a {
    color: var(--article-accent, var(--kl-accent));
    text-decoration: none;
    font-weight: var(--kl-weight-medium);
  }

  /* --- charts (single-hue accent; identity via direct labels, not color) --- */
  .chart {
    margin: var(--kl-space-6) 0;
    padding: var(--kl-space-6);
    border: 1px solid var(--kl-border);
    border-radius: var(--kl-radius-lg, 12px);
    display: grid;
    gap: var(--kl-space-5);
  }

  .chart-title {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-md);
    font-weight: var(--kl-weight-semibold);
    color: var(--kl-ink);
  }

  /* tokenops-rendered SVG — inherits ink via currentColor, scales to width */
  .chart-svg {
    color: var(--kl-ink);
  }

  .chart-svg :global(svg) {
    inline-size: 100%;
    block-size: auto;
    display: block;
  }

  .chart-cmd {
    margin: 0;
    padding: var(--kl-space-2) var(--kl-space-3);
    background: var(--kl-surface-raised, rgba(127, 127, 127, 0.08));
    border: 1px solid var(--kl-border);
    border-radius: var(--kl-radius-sm, 8px);
    font-family: var(--kl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: var(--kl-text-sm);
    color: var(--kl-ink-secondary);
    overflow-x: auto;
    white-space: pre;
  }

  .chart-cmd .prompt {
    color: var(--article-accent, var(--kl-accent));
    user-select: none;
    margin-inline-end: var(--kl-space-2);
  }

  .chart-caption {
    margin: 0;
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    line-height: var(--kl-leading-relaxed);
    color: var(--kl-ink-tertiary);
  }

  .bars {
    display: grid;
    gap: var(--kl-space-4);
  }

  .bar-row {
    display: grid;
    gap: var(--kl-space-1);
  }

  .bar-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--kl-space-3);
  }

  .bar-label {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    font-weight: var(--kl-weight-medium);
    color: var(--kl-ink);
  }

  .bar-value {
    font-family: var(--kl-font-mono, ui-monospace, monospace);
    font-size: var(--kl-text-sm);
    font-weight: var(--kl-weight-semibold);
    color: var(--kl-ink-secondary);
    font-variant-numeric: tabular-nums;
  }

  .bar-track {
    block-size: 10px;
    background: var(--kl-surface-raised, rgba(127, 127, 127, 0.1));
    border-radius: 999px;
  }

  .bar-fill {
    block-size: 100%;
    border-radius: 999px;
    background: color-mix(in oklab, var(--article-accent, var(--kl-accent)) 34%, transparent);
    min-inline-size: 6px;
  }

  .bar-fill.hi {
    background: var(--article-accent, var(--kl-accent));
  }

  .bar-note {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-xs);
    color: var(--kl-ink-tertiary);
  }

  /* ratio hero */
  .ratio {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--kl-space-6);
    align-items: center;
  }

  .ratio-big {
    font-family: var(--kl-font-sans);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: var(--kl-weight-bold);
    letter-spacing: var(--kl-tracking-tight);
    color: var(--article-accent, var(--kl-accent));
    line-height: 1;
  }

  .ratio-bars {
    display: grid;
    gap: var(--kl-space-3);
    min-inline-size: 0;
  }

  .ratio-row {
    display: grid;
    gap: var(--kl-space-1);
  }

  .ratio-label {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-xs);
    color: var(--kl-ink-secondary);
  }

  .ratio-track {
    block-size: 12px;
    background: var(--kl-surface-raised, rgba(127, 127, 127, 0.1));
    border-radius: 999px;
    overflow: hidden;
  }

  .ratio-fill {
    block-size: 100%;
    border-radius: 999px;
  }

  .ratio-fill.input {
    background: var(--article-accent, var(--kl-accent));
  }

  .ratio-fill.output {
    background: var(--kl-ink-secondary);
    min-inline-size: 3px;
  }

  @media (max-width: 520px) {
    .ratio {
      grid-template-columns: 1fr;
      gap: var(--kl-space-4);
    }
  }

  .cta {
    display: grid;
    gap: var(--kl-space-4);
    justify-items: start;
    margin-block-start: var(--kl-space-8);
    padding-block-start: var(--kl-space-8);
    border-block-start: 1px solid var(--kl-border);
  }

  .back {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    color: var(--kl-ink-tertiary);
    text-decoration: none;
  }

  .back:hover {
    color: var(--kl-ink);
  }

  footer {
    border-block-start: 1px solid var(--kl-border);
    padding: var(--kl-space-8) clamp(var(--kl-space-4), 4vw, var(--kl-space-12));
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--kl-space-4);
  }

  .footer-place {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    color: var(--kl-ink-tertiary);
  }
</style>
