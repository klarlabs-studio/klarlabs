---
import Base from '../layouts/Base.astro';
import { products, ossGroups } from '../data/products';
---

<Base
  title="Klarlabs — We build tools that make complex things clear."
  description="Precision software from Munich. Developer infrastructure, AI agent tooling, consumer apps, and open source — built by Klarlabs."
  theme="dark"
  themeToggle
>
  <kl-nav>
    <a class="wordmark" slot="brand" href="/">klar&hairsp;<em>labs</em></a>
    <a href="/#products">Products</a>
    <a href="/#oss">Open Source</a>
    <a href="/#studio">Studio</a>
    <a href="/writing/">Writing</a>
    <span slot="cta" class="nav-actions">
      <kl-button size="sm" variant="secondary" href="https://github.com/klarlabs-studio" target="_blank">
        GitHub
      </kl-button>
      <kl-theme-toggle></kl-theme-toggle>
    </span>
    <a slot="drawer" href="/#products">Products</a>
    <a slot="drawer" href="/#oss">Open Source</a>
    <a slot="drawer" href="/#studio">Studio</a>
    <a slot="drawer" href="/writing/">Writing</a>
  </kl-nav>

  <kl-hero animated>
    <span slot="eyebrow">Klarlabs · Munich</span>
    <h1 slot="title">We build tools that make complex things <em class="accent">clear</em>.</h1>
    <p slot="subtitle">Precision software for developers and AI systems. Engineered, not assembled.</p>
    <span slot="actions" class="hero-actions">
      <kl-button size="lg" href="/#products">View Products</kl-button>
      <kl-button size="lg" variant="ghost" href="/#oss">Open Source</kl-button>
    </span>
  </kl-hero>

  <main>
    <section id="products">
      <span class="section-label">01 Products</span>
      <h2>Tools for building, running, and trusting AI systems.</h2>
      <div class="grid">
        {
          products.map((p) => (
            <kl-product-card
              name={p.name}
              description={p.description}
              href={`/products/${p.slug}/`}
              status={p.status}
              style={`--kl-product-card-accent: ${p.accent}`}
            />
          ))
        }
      </div>
    </section>

    <kl-divider></kl-divider>

    <section id="oss">
      <span class="section-label">02 Open Source</span>
      <h2>The infrastructure behind everything we build.</h2>
      {
        ossGroups.map((group) => (
          <div class="oss-group">
            <h3 class="oss-group-title">{group.title}</h3>
            <div class="oss-list">
              {group.libraries.map((lib) => (
                <kl-oss-card
                  name={lib.name}
                  description={lib.description}
                  repo-href={lib.repoHref}
                  docs-href={lib.docsHref}
                  docs-label={lib.docsLabel}
                />
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <kl-divider></kl-divider>

    <section id="studio">
      <span class="section-label">03 Studio</span>
      <p class="studio-copy">
        Klarlabs is an independent software studio in Munich. One engineer, strong opinions,
        production standards. We design for the long run: typed contracts, evidence over
        promises, and tools that explain themselves. Smart. Präzise. Wertig. Verlässlich.
      </p>
    </section>
  </main>

  <footer>
    <span class="footer-brand">klar&hairsp;<em>labs</em></span>
    <nav aria-label="Footer">
      <a href="https://felixgeelhaar.de" target="_blank" rel="noopener noreferrer">felixgeelhaar.de</a>
      <a href="https://github.com/klarlabs-studio" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://felixgeelhaar.de/blog" target="_blank" rel="noopener noreferrer">Writing</a>
    </nav>
    <span class="footer-place">Munich, Germany</span>
    <span class="footer-copyright">© 2026 Klarlabs</span>
  </footer>
</Base>

<style>
  .wordmark {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-md);
    font-weight: var(--kl-weight-normal);
    letter-spacing: var(--kl-tracking-tight);
    color: var(--kl-ink);
    text-decoration: none;
  }

  .wordmark em,
  .footer-brand em {
    color: var(--kl-accent);
    font-weight: var(--kl-weight-semibold);
    font-style: normal;
  }

  .nav-actions {
    display: inline-flex;
    align-items: center;
    gap: var(--kl-space-3);
  }

  .accent {
    color: var(--kl-accent);
    font-style: normal;
  }

  .hero-actions {
    display: flex;
    gap: var(--kl-space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  main {
    max-inline-size: var(--kl-content-xl);
    margin-inline: auto;
    padding-block: var(--kl-space-20);
    padding-inline: clamp(var(--kl-space-4), 4vw, var(--kl-space-12));
    display: grid;
    gap: var(--kl-space-16);
  }

  section {
    display: grid;
    gap: var(--kl-space-6);
  }

  .section-label {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-xs);
    font-weight: var(--kl-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--kl-tracking-caps);
    color: var(--kl-accent);
  }

  h2 {
    margin: 0;
    margin-block-start: calc(-1 * var(--kl-space-4));
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-lg);
    font-weight: var(--kl-weight-bold);
    letter-spacing: var(--kl-tracking-tight);
    color: var(--kl-ink);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: var(--kl-space-6);
  }

  .oss-group {
    display: grid;
    gap: var(--kl-space-3);
    margin-block-start: var(--kl-space-5);
  }

  .oss-group-title {
    margin: 0;
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    font-weight: var(--kl-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--kl-tracking-caps);
    color: var(--kl-ink-secondary);
  }

  .oss-list {
    display: grid;
    gap: var(--kl-space-2);
  }

  .studio-copy {
    margin: 0;
    max-inline-size: var(--kl-content-md);
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-md);
    line-height: var(--kl-leading-relaxed);
    color: var(--kl-ink-secondary);
  }

  footer {
    border-block-start: 1px solid var(--kl-border);
    padding: var(--kl-space-8) clamp(var(--kl-space-4), 4vw, var(--kl-space-12));
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--kl-space-4);
  }

  .footer-brand {
    font-family: var(--kl-font-sans);
    color: var(--kl-ink);
  }

  .footer-place,
  .footer-copyright {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    color: var(--kl-ink-tertiary);
  }

  footer nav {
    display: flex;
    gap: var(--kl-space-6);
  }

  footer nav a {
    font-family: var(--kl-font-sans);
    font-size: var(--kl-text-sm);
    color: var(--kl-ink-tertiary);
    text-decoration: none;
    transition: color var(--kl-duration-fast) var(--kl-ease-default);
  }

  footer nav a:hover {
    color: var(--kl-accent);
  }
</style>
